# Candor environment variables — copy to .env.local and fill in. NEVER commit real values.
# In Netlify, set these under Site settings → Environment variables.

# --- Client-side (exposed to the browser; must be prefixed VITE_) ---

# Web3Forms access key for the waitlist form (https://web3forms.com).
VITE_WEB3FORMS_KEY=your-web3forms-access-key

# Supabase (Week 2 — auth + receipts persistence). Both values are client-safe:
# the anon key is public by design; row-level security protects the data.
# NEVER put the service_role key here or in any VITE_ variable.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Sentry DSN for browser error + performance monitoring. The DSN is safe to expose client-side.
VITE_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# Environment label that shows up in Sentry (e.g. "production", "preview", "development").
# Optional — defaults to Vite's MODE if unset.
VITE_SENTRY_ENVIRONMENT=production

# --- Server-side only (Netlify Functions; NEVER prefixed VITE_) ---
# Plaid (sandbox). From dashboard.plaid.com → Developers → Keys.
PLAID_CLIENT_ID=your-plaid-client-id
PLAID_SECRET=your-plaid-sandbox-secret
PLAID_ENV=sandbox

# Anthropic API key — OPTIONAL. Powers the advisor's free-form LLM fallback
# (advisor-ask function). Without it, the advisor still works fully via the
# deterministic rules database; free-form edge questions return 503 gracefully.
ANTHROPIC_API_KEY=sk-ant-your-key

# --- Build-time only (NEVER prefixed VITE_, NEVER exposed to the browser) ---
# Used by @sentry/vite-plugin to upload source maps during `npm run build`.
# Set these ONLY in the Netlify build environment / CI — do not put the auth token in a committed file.
SENTRY_ORG=candor
SENTRY_PROJECT=candor-web
SENTRY_AUTH_TOKEN=sntrys_your_build_token_with_project_releases_scope
